{
  "name": "unoc-frontend-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "UNOC Frontend (Vue 3 + TypeScript + Vite) — topology canvas + smart SVG cockpits",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "prelint": "node -e \"try{require('fs').rmSync('.eslintcache',{force:true})}catch(e){}\"",
    "lint": "npm run prelint && eslint --no-cache --ext .ts,.tsx,.vue src",
    "lint:fix": "eslint --no-cache --ext .ts,.tsx,.vue src --fix",
    "format": "prettier --write .",
    "test": "cross-env NODE_ENV=test VITE_DEVTOOLS=0 vitest run",
    "test:nocov": "cross-env NODE_ENV=test VITE_DEVTOOLS=0 vitest run -c vitest.nocov.config.ts",
    "test:watch": "cross-env NODE_ENV=test VITE_DEVTOOLS=0 vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install",
    "e2e:codegen": "playwright codegen http://localhost:4173",
    "analyze": "vite build --mode analyze",
    "gen:types": "python ../tools/gen_ts_types.py"
  },
  "dependencies": {
    "d3": "^7.8.5",
    "pinia": "^2.1.7",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.7",
    "@playwright/test": "^1.45.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vue/test-utils": "^2.4.5",
    "cross-env": "^10.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.22.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.2.5",
    "typescript": "^5.4.0",
    "vite": "^5.0.0",
    "vitest": "^1.5.0",
    "vue-tsc": "^2.0.0"
  },
  "prettier": {
    "semi": false,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "none"
  }
}
