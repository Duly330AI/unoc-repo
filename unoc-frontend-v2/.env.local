# Frontend Environment Variables

# Log Level: 'debug' | 'info' | 'warn' | 'error' | 'off'
# Default: 'info' in dev, 'warn' in production
VITE_LOG_LEVEL=warn

# Muted log prefixes (comma-separated)
# Default in dev: PortSummaryManager, wsClient, metricsStore, linkMetricsStore, OLTCockpit, LAYOUT
# VITE_MUTED_LOGS=[PortSummaryManager],[wsClient],[LAYOUT]

# To enable verbose logs (show everything):
# VITE_LOG_LEVEL=debug
# VITE_MUTED_LOGS=
