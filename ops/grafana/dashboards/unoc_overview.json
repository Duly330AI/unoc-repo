{
  "id": null,
  "uid": "unoc-overview",
  "title": "UNOC v3 - Performance Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "path",
        "type": "query",
        "label": "API Path",
        "hide": 0,
        "datasource": {
          "type": "prometheus",
          "uid": "PBFA97CFB590B2093"
        },
        "query": "label_values(http_request_duration_seconds_count, path)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "type": "timeseries",
      "title": "API Request Latency (p95)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Status Re-computation Duration (p95)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(status_recompute_duration_seconds_bucket[5m])) by (le)) * 1000",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Traffic Engine Tick Duration (avg)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(traffic_tick_duration_seconds_sum[5m]) / rate(traffic_tick_duration_seconds_count[5m]) * 1000",
          "legendFormat": "avg"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Requests per second (RPS)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_request_duration_seconds_count[1m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (5xx)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_request_duration_seconds_count{status=\"5xx\"}[5m])) / sum(rate(http_request_duration_seconds_count[5m]))",
          "legendFormat": "error rate"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Top 5 Endpoints by RPS",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(5, sum(rate(http_request_duration_seconds_count[1m])) by (path))",
          "legendFormat": "{{path}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Traffic Tick Phase p95 (ms)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 40 },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "links": [],
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(traffic_tick_phase_seconds_bucket[5m])) by (le, phase)) * 1000",
          "legendFormat": "{{phase}}"
        }
      ]
    }
  ]
}
