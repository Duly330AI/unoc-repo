{
    "toolsets": [
        {
            "name": "UNOC Dev Tools",
            "description": "UNOC local dev on Windows PowerShell. INTEGRATION CRISIS: GO services built but NOT used! Priority: Wire Optical+Status into production code.",
            "cwd": "c:/noc_project/UNOC/unoc",
            "tools": [
                // ---------- 🚀 CORE WORKFLOWS 🚀 ----------
                {
                    "id": "quality-all-backend",
                    "label": "✅ Quality Gate: All Backend (Lint + Format + Tests on SQLite)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' -m ruff check . --fix; & '${workspaceFolder}/.venv/Scripts/python.exe' -m isort .; & '${workspaceFolder}/.venv/Scripts/python.exe' -m black .; & '${workspaceFolder}/.venv/Scripts/python.exe' -m pytest -q"
                },
                {
                    "id": "quality-all-frontend",
                    "label": "✅ Quality Gate: All Frontend (Lint + Build + Tests)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "npm run lint --prefix unoc-frontend-v2; npm run build --prefix unoc-frontend-v2; npm test --prefix unoc-frontend-v2"
                },
                {
                    "id": "backend-run-postgres",
                    "label": "🚀 Run: Backend (with PostgreSQL)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' run.py"
                },
                {
                    "id": "frontend-run-dev",
                    "label": "🚀 Run: Frontend (dev server)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "npm run dev --prefix unoc-frontend-v2"
                },
                // ---------- 🐳 DOCKER & DATABASE 🐳 ----------
                {
                    "id": "docker-start-db",
                    "label": "🐳 Docker: Start PostgreSQL Database",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "docker compose up -d"
                },
                {
                    "id": "docker-stop-db",
                    "label": "🐳 Docker: Stop PostgreSQL Database",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "docker compose down"
                },
                {
                    "id": "docker-status",
                    "label": "🕵️ Docker: Check Container Status",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "docker ps"
                },
                {
                    "id": "db-reset-seed",
                    "label": "♻️ DB: Reset and Seed (PostgreSQL)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' scripts/reset_dev_db.py --force --seed"
                },
                // ---------- 🚀 GO SERVICES (Week 1-3: 5 Services) 🚀 ----------
                // ✅ Traffic Engine (port 8080) - INTEGRATED & WORKING
                // ❌ Optical PathFinder (port 50051) - RUNS BUT NOT USED (needs integration!)
                // ❌ Status Propagation (port 50053) - RUNS BUT NOT USED (needs integration!)
                // ⚠️ Batch Operations (port 50052) - RUNS, API exists, NO UI
                // 🚧 Port Summary (port 50054) - IN DEVELOPMENT (Week 3, Day 18-20)
                // CRITICAL: Services are built & tested, just not called by production code!
                {
                    "id": "go-start-services",
                    "label": "🚀 Go: Start All Services (Traffic, Optical, Status, Batch, PortSummary)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": ".\\scripts\\start_all_services.ps1"
                },
                {
                    "id": "go-stop-services",
                    "label": "🛑 Go: Stop All Services",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": ".\\scripts\\stop_all_services.ps1"
                },
                {
                    "id": "go-test-all",
                    "label": "🧪 Go: Run All Tests",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "cd engine-go; go test ./... -v"
                },
                {
                    "id": "go-build-services",
                    "label": "🔨 Go: Build All Services",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "cd engine-go; go build ./cmd/optical-service ./cmd/batch-service ./cmd/status-service"
                },
                {
                    "id": "go-integration-test",
                    "label": "🔗 Go: Run Integration Tests (Python gRPC clients)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' -m pytest -q test_grpc_integration.py"
                },
                {
                    "id": "go-check-ports",
                    "label": "🕵️ Go: Check Service Ports (8080, 50051, 50052, 50053, 50054)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "Write-Host 'Checking Go Services...'; Test-NetConnection -ComputerName localhost -Port 8080; Test-NetConnection -ComputerName localhost -Port 50051; Test-NetConnection -ComputerName localhost -Port 50052; Test-NetConnection -ComputerName localhost -Port 50053; Test-NetConnection -ComputerName localhost -Port 50054"
                },
                {
                    "id": "go-port-summary-start",
                    "label": "🚀 Go: Start Port Summary Service (50054)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "cd engine-go; go run ./cmd/port-summary-service"
                },
                {
                    "id": "go-port-summary-test",
                    "label": "🧪 Go: Test Port Summary Service",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "cd engine-go; go test ./cmd/port-summary-service -v"
                },
                {
                    "id": "go-port-summary-benchmark",
                    "label": "⏱️ Go: Benchmark Port Summary (70, 200, 1000 devices)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' tools/benchmark_port_summary.py"
                },
                // ---------- 🕵️ DIAGNOSTICS & DEBUGGING 🕵️ ----------
                {
                    "id": "check-port-5432",
                    "label": "🕵️ Diagnostics: Check PostgreSQL Port",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "Test-NetConnection -ComputerName localhost -Port 5432"
                },
                {
                    "id": "db-query-psql",
                    "label": "🗄️ DB: Run SQL Query (psql)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "docker exec -it unoc-postgres psql -U unoc -d unocdb -c 'SELECT COUNT(*) FROM device;'"
                },
                {
                    "id": "backend-test-single-file",
                    "label": "🧪 Tests: Run Single Backend File",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' -m pytest -q backend/tests/FILE_TO_TEST.py"
                },
                {
                    "id": "perf-load-test-200",
                    "label": "⏱️ Perf: Realistic Load Test (200 devices, 60s)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' tools/realistic_load_test.py --devices 200 --duration 60"
                },
                {
                    "id": "perf-profile-traffic",
                    "label": "⏱️ Perf: Profile Traffic Tick (5 ticks)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' tools/profile_traffic_tick.py --ticks 5 --output traffic_profile.stats"
                },
                {
                    "id": "perf-profile-status",
                    "label": "⏱️ Perf: Profile Status Recompute (200 devices)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "& '${workspaceFolder}/.venv/Scripts/python.exe' tools/profile_status_recompute.py --devices 200 --output status_profile.stats"
                },
                {
                    "id": "perf-harness-run",
                    "label": "⏱️ Perf: Run Performance Harness (with profile)",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "$env:UNOC_PERF_PROFILE=1; & '${workspaceFolder}/.venv/Scripts/python.exe' -m pytest -m perf"
                },
                {
                    "id": "kill-stuck-servers",
                    "label": "🛑 Emergency: Kill Stuck Backend Processes",
                    "type": "terminal",
                    "shell": "powershell.exe",
                    "command": "Get-CimInstance Win32_Process | Where-Object { $_.CommandLine -match 'run.py|uvicorn|watchfiles' } | ForEach-Object { try { Stop-Process -Id $_.ProcessId -Force -ErrorAction Stop } catch {} }"
                }
            ]
        }
    ]
}