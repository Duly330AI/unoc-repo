# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# DATABASE_URL: Local Docker Compose Postgres dev defaults for the recovered UNOC stack.
# The unoc/unocpw values are non-secret local docker-compose defaults only.
DATABASE_URL=postgresql+psycopg://unoc:unocpw@localhost:5432/unocdb

# Prisma SQLite alternative for the Node/Prisma dev line:
# DATABASE_URL="file:./dev.db"

# -- Application Settings --
# Set to 'inmemory' to use a temporary SQLite DB for tests. Leave empty for file/Postgres.
UNOC_PERSISTENCE=
# Enable development-only features (debug endpoints /api/debug/* and the Debug tab). Set to 1 to enable.
UNOC_DEV_FEATURES=1
# Disable uvicorn auto-reload to avoid Flask/FastAPI reload noise in local recovery/dev runs.
UNOC_DISABLE_RELOAD=1
# Auto-assign a default hardware model to new devices if not specified. Set to 1 to enable.
AUTO_ASSIGN_DEFAULT_HARDWARE=1
