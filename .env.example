# UNOC Backend Configuration
# Copy this file to .env and set your local values.

# -- Database --
# Use this URL to connect to the local PostgreSQL container started with Docker Compose.
DATABASE_URL=postgresql+psycopg://unoc:unocpw@localhost:5432/unocdb

# -- Application Settings --
# Set to 'inmemory' to use a temporary SQLite DB for tests. Leave empty for file/Postgres.
UNOC_PERSISTENCE=
# Enable development-only features (e.g., debug endpoints). Set to 1 to enable.
UNOC_DEV_FEATURES=1
# Auto-assign a default hardware model to new devices if not specified. Set to 1 to enable.
AUTO_ASSIGN_DEFAULT_HARDWARE=1
