# ============================================
# UNOC Docker Compose - MINIMAL Configuration
# ============================================
# 
# This file ONLY starts:
#   1. PostgreSQL (database)
#   2. Prometheus (metrics)
#   3. Grafana (visualization)
#
# ALL Go services and Python backend are started via scripts:
#   - Go Services: ./scripts/start_all_services.ps1
#   - Python Backend: conda activate unoc-env && python run.py
#
# DO NOT add any Go services or backend here!
# ============================================

services:
  # ============================================
  # PostgreSQL Database (Port 5432)
  # ============================================
  postgres:
    image: postgres:16-alpine
    container_name: unoc-postgres
    ports:
      - "5432:5432"
    environment:
      POSTGRES_USER: unoc
      POSTGRES_PASSWORD: unocpw
      POSTGRES_DB: unocdb
      POSTGRES_INITDB_ARGS: "--encoding=UTF8 --locale=C"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U unoc -d unocdb"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    volumes:
      - pgdata:/var/lib/postgresql/data
      - ./ops/postgres/initdb:/docker-entrypoint-initdb.d:ro
      - ./logs/postgres:/var/log/postgresql
    restart: unless-stopped
    networks:
      - unoc-network

  # ============================================
  # REMOVED: All Go services (use start_all_services.ps1 instead)
  # ============================================
  # traffic-engine - REMOVED (start via script)
  # optical-service - REMOVED (start via script)
  # status-service - REMOVED (start via script)
  # batch-service - REMOVED (start via script)
  # backend - REMOVED (start via python run.py)

  # ============================================
  # Prometheus (Metrics Collection - Port 9090)
    build:
      context: ./engine-go
      dockerfile: Dockerfile.traffic
    container_name: unoc-traffic-engine
    ports:
      - "8080:8080"
    environment:
      - TRAFFIC_PORT=8080
      - LOG_LEVEL=info
      - DATABASE_URL=postgres://unoc:unocpw@postgres:5432/unocdb?sslmode=disable
    volumes:
      - ./logs/traffic:/var/log/traffic
    # TODO: Implement proper health check endpoint in Go service
    # healthcheck:
    #   test: ["CMD", "curl", "-f", "http://localhost:8080/health"]
    #   interval: 15s
    #   timeout: 5s
    #   retries: 3
    #   start_period: 20s
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - unoc-network

  # ============================================
  # Go Service: Status Propagation (Port 50053)
  # ============================================
  status-service:
    build:
      context: ./engine-go
      dockerfile: Dockerfile.status
    container_name: unoc-status-service
    ports:
      - "50053:50053"
    environment:
      - STATUS_PORT=50053
      - LOG_LEVEL=info
      - DATABASE_URL=postgres://unoc:unocpw@postgres:5432/unocdb?sslmode=disable
    volumes:
      - ./logs/status:/var/log/status
    # TODO: Implement proper health check endpoint in Go service
    # healthcheck:
    #   test: ["CMD", "/app/status-service", "--health"]
    #   interval: 15s
    #   timeout: 5s
    #   retries: 3
    #   start_period: 20s
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - unoc-network

  # ============================================
  # Go Service: Optical PathFinder (Port 50051)
  # CRITICAL: Must start BEFORE batch-service!
  # ============================================
  optical-service:
    build:
      context: ./engine-go
      dockerfile: Dockerfile.optical
    container_name: unoc-optical-service
    ports:
      - "50051:50051"
    environment:
      - OPTICAL_PORT=50051
      - LOG_LEVEL=info
      - DATABASE_URL=postgres://unoc:unocpw@postgres:5432/unocdb?sslmode=disable
    volumes:
      - ./logs/optical:/var/log/optical
    # TODO: Implement proper health check endpoint in Go service
    # healthcheck:
    #   test: ["CMD-SHELL", "nc -z localhost 50051 || exit 1"]
    #   interval: 15s
    #   timeout: 5s
    #   retries: 3
    #   start_period: 20s
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
    networks:
      - unoc-network

  # ============================================
  # Go Service: Batch Operations (Port 50052)
  # DEPENDS ON: optical-service (gRPC calls)
  # ============================================
  batch-service:
    build:
      context: ./engine-go
      dockerfile: Dockerfile.batch
    container_name: unoc-batch-service
    ports:
      - "50052:50052"
    environment:
      - BATCH_PORT=50052
      - OPTICAL_SERVICE_URL=optical-service:50051
      - LOG_LEVEL=info
      - DATABASE_URL=postgres://unoc:unocpw@postgres:5432/unocdb?sslmode=disable
    volumes:
      - ./logs/batch:/var/log/batch
    # TODO: Implement proper health check endpoint in Go service
    # healthcheck:
    #   test: ["CMD", "/app/batch-service", "--health"]
    #   interval: 15s
    #   timeout: 5s
    #   retries: 3
    #   start_period: 30s
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      # optical-service:
      #   condition: service_healthy
    networks:
      - unoc-network

  # ============================================
  # Python FastAPI Backend (Port 5001)
  # ============================================
  backend:
    build:
      context: .
      dockerfile: Dockerfile.backend
    container_name: unoc-backend
    ports:
      - "5001:5001"
    environment:
      - UNOC_ASYNC_MODE=threading
      - UNOC_PORT=5001
      - UNOC_DEV_FEATURES=1
      - AUTO_ASSIGN_DEFAULT_HARDWARE=1
      - DATABASE_URL=postgresql+psycopg://unoc:unocpw@postgres:5432/unocdb
      - BATCH_SERVICE_URL=batch-service:50052
      - OPTICAL_SERVICE_URL=optical-service:50051
      - STATUS_SERVICE_URL=status-service:50053
      - TRAFFIC_ENGINE_URL=http://traffic-engine:8080
    volumes:
      - ./logs/backend:/var/log/backend
      - ./backend:/app/backend:ro
    # TODO: Backend health endpoint needs to be accessible from docker
    # healthcheck:
    #   test: ["CMD", "curl", "-f", "http://localhost:5001/health"]
    #   interval: 15s
    #   timeout: 5s
    #   retries: 3
    #   start_period: 30s
    restart: unless-stopped
    depends_on:
      postgres:
        condition: service_healthy
      # batch-service:
      #   condition: service_healthy
      # optical-service:
      #   condition: service_healthy
      # status-service:
      #   condition: service_healthy
      # traffic-engine:
      #   condition: service_healthy
    networks:
      - unoc-network

  # ============================================
  # Prometheus (Metrics Collection)
  # ============================================
  # ============================================
  # Prometheus (Metrics Collection)
  # ============================================
  prometheus:
    image: prom/prometheus:v2.54.1
    container_name: unoc-prometheus
    ports:
      - "9090:9090"
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.retention.time=30d"
      - "--web.enable-lifecycle"
    volumes:
      - ./ops/prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - ./ops/prometheus/alerts:/etc/prometheus/alerts:ro
      - prometheus_data:/prometheus
    restart: unless-stopped
    depends_on:
      - postgres
    networks:
      - unoc-network

  # ============================================
  # Grafana (Visualization)
  # ============================================
  grafana:
    image: grafana/grafana:10.4.12
    container_name: unoc-grafana
    ports:
      - "3000:3000"
    environment:
      GF_SECURITY_ADMIN_USER: admin
      GF_SECURITY_ADMIN_PASSWORD: unoc2025
      GF_ANALYTICS_REPORTING_ENABLED: "false"
      GF_ANALYTICS_CHECK_FOR_UPDATES: "false"
    volumes:
      - ./ops/grafana/provisioning/datasources:/etc/grafana/provisioning/datasources:ro
      - ./ops/grafana/dashboards:/etc/grafana/provisioning/dashboards:ro
      - grafana_data:/var/lib/grafana
    restart: unless-stopped
    depends_on:
      - prometheus
    networks:
      - unoc-network

# ============================================
# Volumes (Persistent Data)
# ============================================
volumes:
  pgdata:
    driver: local
  prometheus_data:
    driver: local
  grafana_data:
    driver: local

# ============================================
# Networks
# ============================================
networks:
  unoc-network:
    driver: bridge
    ipam:
      config:
        - subnet: 172.28.0.0/16
